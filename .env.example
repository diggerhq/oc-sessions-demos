# Copy to .env.local for local dev (Next.js loads it automatically),
# or set these as Environment Variables in your Vercel project.

# Your OpenComputer API key — from https://app.opencomputer.dev
# Used server-side only (in the /api routes); never shipped to the browser.
OPENCOMPUTER_API_KEY=

# Your Anthropic key — stored in OpenComputer's secret store and sealed;
# it never enters a sandbox, the model's prompt, or this app's browser code.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown). NEXT_PUBLIC_* is the only one the browser sees.
# OC_API_URL=https://api.opencomputer.dev
# NEXT_PUBLIC_OC_API_URL=https://api.opencomputer.dev

# --- To preview the UI locally with the mock (see mock/README.md) ---
# Set both URLs to the mock, and any placeholder is fine for the two keys above:
# OC_API_URL=http://localhost:8787
# NEXT_PUBLIC_OC_API_URL=http://localhost:8787
